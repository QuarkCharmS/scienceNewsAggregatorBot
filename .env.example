# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# NASA API key (free) — https://api.nasa.gov
NASA_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram channel ID (e.g. @mychannel or a numeric ID like -1001234567890)
TELEGRAM_CHANNEL_ID=

# Time to post the daily digest (24-hour format, server local time)
DIGEST_TIME=09:00
